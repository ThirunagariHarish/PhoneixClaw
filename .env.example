# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_GROUP=default-group
KAFKA_AUTO_OFFSET_RESET=earliest

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://phoenixtrader:localdev@localhost:5432/phoenixtrader
POSTGRES_USER=phoenixtrader
POSTGRES_PASSWORD=localdev
POSTGRES_DB=phoenixtrader

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Auth / JWT ===
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Credential Encryption ===
CREDENTIAL_ENCRYPTION_KEY=generate-with-python-c-from-cryptography.fernet-import-Fernet;print(Fernet.generate_key().decode())

# === Alpaca (default broker for dev) ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# === Discord ===
DISCORD_BOT_TOKEN= OTAzMTU0NjQyMDIyNzE5NDk4.G--wd8.ouCEb5Cd3lO1R3ctqiIV76yhKl2gHQjsnLvR5Y
