# ═══════════════════════════════════════════════════════════════════════════
# Phoenix Claw — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=phoenixtrader
POSTGRES_PASSWORD=changeme
POSTGRES_DB=phoenixtrader
DATABASE_URL=postgresql+asyncpg://phoenixtrader:changeme@postgres:5432/phoenixtrader

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth / JWT ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-generate-a-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MinIO (Object Storage) ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000

# ── Broker (Alpaca) — leave blank for paper-only ─────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Ollama / LLM ─────────────────────────────────────────────────────────
OLLAMA_EXPAND_MODEL=llama3.2:1b

# ── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Discord (optional) ───────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_TARGET_CHANNELS=

# ── Phoenix API URL (used by Claude Code subprocesses for progress callbacks) ──
# Local dev: http://localhost:8011
# Docker (internal): http://phoenix-api:8011  (set automatically in docker-compose)
PHOENIX_API_URL=http://localhost:8011

# ── Anthropic (required for backtesting / Claude Code agents) ────────────────
ANTHROPIC_API_KEY=

# ── Security (REQUIRED — change before deploying to production) ──────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=CHANGE-ME-generate-with-python-c-from-cryptography.fernet-import-Fernet-print-Fernet.generate_key
FERNET_KEY=${CREDENTIAL_ENCRYPTION_KEY}

# ── CORS — set to your production frontend domain ────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Trading Safety Guards ────────────────────────────────────────────────────
# Keep ENABLE_TRADING=false until broker integration is verified end-to-end
DRY_RUN_MODE=true
ENABLE_TRADING=false

# ── Prediction Markets Agent (Phase 15) ──────────────────────────────────────
# TopBetsAgent — autonomous 24/7 scanner for high-confidence prediction market bets.
# All trades in Phase 15 are paper-mode only.
PM_TOP_BETS_ENABLED=true
PM_TOP_BETS_VENUE=robinhood_predictions
PM_TOP_BETS_CYCLE_INTERVAL_S=60
PM_RESEARCH_ENABLED=true

# ── Phase 6: Smart Context Builder ───────────────────────────────────────────
# Karpathy-style context engineering: priority-tiered, token-budgeted context assembly.
# Set to true to enable dynamic wiki/trade/manifest injection into live agent prompts.
ENABLE_SMART_CONTEXT=false
WIKI_CONTEXT_TOKEN_BUDGET=8000
