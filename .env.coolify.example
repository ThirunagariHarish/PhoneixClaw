###############################################################################
# PhoenixTrade — Coolify Environment Variables
#
# Copy these into Coolify's Environment Variables panel.
# Variables marked [REQUIRED] must be set before first deploy.
# Variables with defaults are optional — the default will be used if unset.
###############################################################################

# === REQUIRED: Core Infrastructure ===
DATABASE_URL=postgresql+asyncpg://phoenixtrader:CHANGE_ME@postgres:5432/phoenixtrader
REDIS_URL=redis://redis:6379

# ─── Database (PostgreSQL) ─────────────────────────────────────────────
# [REQUIRED] Strong password for the PostgreSQL database
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_USER=phoenixtrader
POSTGRES_DB=phoenixtrader

# ─── Security — JWT ───────────────────────────────────────────────────
# [REQUIRED] Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Security — Credential Encryption ─────────────────────────────────
# [REQUIRED] Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# ─── Discord ──────────────────────────────────────────────────────────
# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=
# Comma-separated channel IDs to monitor
DISCORD_TARGET_CHANNELS=

# ─── Trading Execution ───────────────────────────────────────────────
ENABLE_TRADING=true
DRY_RUN_MODE=false
BUFFER_PERCENTAGE=0.15
BUFFER_MAX_PERCENTAGE=0.30
BUFFER_MIN_PRICE=0.01
MAX_POSITION_SIZE=10
MAX_DAILY_LOSS=1000.0

# ─── Trade Approval ──────────────────────────────────────────────────
# "auto" = execute immediately | "manual" = require human approval
APPROVAL_MODE=auto
APPROVAL_TIMEOUT_SECONDS=300

# ─── Position Monitor ────────────────────────────────────────────────
MONITOR_POLL_INTERVAL_SECONDS=5
DEFAULT_PROFIT_TARGET=0.30
DEFAULT_STOP_LOSS=0.20
TRAILING_STOP_ENABLED=false
TRAILING_STOP_OFFSET=0.10

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── MinIO (Object Storage) ────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MODEL_BUCKET=phoenix-models

# ─── Anthropic (Agent AI) ──────────────────────────────────────────────
# [REQUIRED for agent orchestrator] Get from console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Internal Service URLs (auto-configured, rarely need changing) ────
BROKER_GATEWAY_URL=http://phoenix-broker-gateway:8040
INFERENCE_SERVICE_URL=http://phoenix-inference-service:8045
FEATURE_PIPELINE_URL=http://phoenix-feature-pipeline:8055

# ─── CORS (set to your actual domain in production) ─────────────────
CORS_ORIGINS=https://your-domain.com

# ─── Broker Credentials (optional — for live execution) ─────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ─── Ollama (when enabled) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434

# ─── Build (optional) ────────────────────────────────────────────────
# Increment to force dashboard rebuild (e.g. when Backtesting tab doesn't appear)
# CACHEBUST=2
