# Phoenix Claw v2 — Production Environment Variables
# Copy to .env.production and fill in all values before deploying.

# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=phoenixtrader
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=phoenixtrader
DATABASE_URL=postgresql+asyncpg://phoenixtrader:CHANGE_ME_STRONG_PASSWORD@postgres:5432/phoenixtrader

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_HEX
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ─── MinIO (Object Storage) ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=http://minio:9000

# ─── Ollama (LLM) ─────────────────────────────────────────────────────────
OLLAMA_EXPAND_MODEL=llama3.2:1b

# ─── Deployment ────────────────────────────────────────────────────────────
# Domain configured in Coolify — Traefik handles SSL via Let's Encrypt
DOMAIN=cashflowus.com

# ─── Agent VPS Communication ──────────────────────────────────────────────
# These are used by the API gateway to SSH into agent VPS instances
# Set per-instance via the dashboard, not globally

# ─── Discord (for backtesting agent) ──────────────────────────────────────
# DISCORD_BOT_TOKEN=your_discord_bot_token

# ─── Robinhood (for live trading agents) ──────────────────────────────────
# RH_USERNAME=your_robinhood_email
# RH_PASSWORD=your_robinhood_password
# RH_TOTP_SECRET=your_2fa_totp_secret
# PAPER_MODE=true
